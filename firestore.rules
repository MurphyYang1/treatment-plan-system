rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function hasOnlyKeys(keys) {
      return request.resource.data.keys().hasOnly(keys);
    }

    function changedOnlyKeys(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    match /signingSessions/{sessionId} {
      allow read: if true;

      allow create: if hasOnlyKeys([
          'status',
          'quotation',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.status == 'pending';

      allow update: if resource.data.status == 'pending'
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly([
          'status',
          'quotation',
          'createdAt',
          'updatedAt'
        ])
        && changedOnlyKeys([
          'quotation',
          'updatedAt'
        ]);

      allow delete: if false;
    }

    match /signedQuotations/{quotationId} {
      allow read, write: if false;
    }
  }
}
